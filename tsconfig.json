{
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".git",
    "lib",
    "test"
  ],
  "compilerOptions": {
    "lib": [
      "ESNext"
    ],
    "target": "ESNext",
    "types": ["node"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "lib",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
