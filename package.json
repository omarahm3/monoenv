{
  "name": "monoenv",
  "version": "1.1.0",
  "description": "better handling of multiple applications dotenv files in monorepos",
  "author": "omarahm3",
  "repository": "https://github.com/omarahm3/monoenv",
  "homepage": "https://github.com/omarahm3/monoenv",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "monoenv": "./lib/bin/run.js"
  },
  "preferGlobal": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('lib', { recursive: true, force: true })\" && tsc",
    "test": "node --test --experimental-test-coverage --test-coverage-exclude=\"test/**\" \"test/**/*.test.ts\"",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "./lib/**/*"
  ],
  "keywords": [],
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "minimist": "^1.2.8",
    "yaml": "^2.9.0"
  }
}
